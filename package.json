{
  "name": "md2idx",
  "version": "0.2.0",
  "description": "md2idx — Markdown to indexed JSON. Slice big docs with jq, feed LLMs only what they need.",
  "keywords": [
    "context-window",
    "llm",
    "llm-agent",
    "markdown",
    "markdown-index",
    "markdown-parser",
    "markdown-splitter",
    "markdown-toc",
    "token-optimization"
  ],
  "homepage": "https://github.com/oubakiou/md2idx#readme",
  "bugs": {
    "url": "https://github.com/oubakiou/md2idx/issues"
  },
  "license": "MIT",
  "author": "oubakiou",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oubakiou/md2idx.git"
  },
  "bin": {
    "md2idx": "dist/md2idx.mjs"
  },
  "files": [
    "dist/md2idx.mjs",
    "dist/md2idx.d.mts",
    "README.md",
    "README_ja.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/md2idx.d.mts",
      "default": "./dist/md2idx.mjs"
    }
  },
  "scripts": {
    "build": "vp pack --dts",
    "prepublishOnly": "npm run build",
    "build:watch": "vp build --watch",
    "dev": "vp dev",
    "test": "vp test",
    "test:watch": "vp test --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.80",
    "@openai/codex": "0.x",
    "@types/node": "^24.0.0",
    "oxlint-tsgolint": "0.x",
    "typescript": "^6.0.2",
    "typescript-language-server": "^5.3.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-plus": "0.x",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
